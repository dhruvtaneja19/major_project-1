    <!-- ==================== SAFETY PILLARS ==================== -->
    <model name="pillar_nw">
      <static>true</static>
      <link name="link">
        <collision name="c"><geometry><cylinder><radius>0.28</radius><length>2.2</length></cylinder></geometry></collision>
        <visual name="v"><geometry><cylinder><radius>0.28</radius><length>2.2</length></cylinder></geometry>
          <material><ambient>0.9 0.75 0.1 1</ambient><diffuse>0.95 0.8 0.15 1</diffuse></material>
