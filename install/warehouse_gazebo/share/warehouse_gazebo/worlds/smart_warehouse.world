<?xml version="1.0" ?>
<sdf version="1.6">
  <world name="smart_warehouse">

    <!-- ==================== LIGHTING ==================== -->
    <include>
      <uri>model://sun</uri>
    </include>

    <include>
      <uri>model://ground_plane</uri>
    </include>

    <scene>
      <ambient>0.6 0.6 0.6 1.0</ambient>
      <background>0.9 0.9 0.9 1.0</background>
      <shadows>true</shadows>
    </scene>

    <!-- ==================== FLOOR (warehouse) ==================== -->
    <model name="warehouse_floor">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>16 12 0.01</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>16 12 0.01</size></box></geometry>
          <material>
            <ambient>0.7 0.7 0.65 1</ambient>
            <diffuse>0.7 0.7 0.65 1</diffuse>
          </material>
        </visual>
      </link>
      <pose>0 0 0.005 0 0 0</pose>
    </model>

    <!-- ==================== PERIMETER WALLS ==================== -->
    <!-- North wall -->
    <model name="wall_north">
      <static>true</static>
      <link name="link">
        <collision name="c"><geometry><box><size>16 0.15 2.5</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>16 0.15 2.5</size></box></geometry>
          <material><ambient>0.6 0.6 0.55 1</ambient><diffuse>0.6 0.6 0.55 1</diffuse></material>
        </visual>
      </link>
      <pose>0 6 1.25 0 0 0</pose>
    </model>
    <!-- South wall -->
