      <link name="link">
        <collision name="c"><geometry><box><size>0.4 2.6 1.2</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.4 2.6 1.2</size></box></geometry>
          <material><ambient>0.55 0.55 0.6 1</ambient><diffuse>0.6 0.6 0.65 1</diffuse></material>
