{
  "python.autoComplete.extraPaths": [
    "/opt/ros/humble/lib/python3.10/dist-packages",
    "/opt/ros/humble/local/lib/python3.10/dist-packages",
    "${workspaceFolder}/install/warehouse_description/lib/python3.10/dist-packages",
    "${workspaceFolder}/install/warehouse_gazebo/lib/python3.10/dist-packages",
    "${workspaceFolder}/install/mapf_planner/lib/python3.10/dist-packages",
    "${workspaceFolder}/install/robot_controller/lib/python3.10/dist-packages",
    "${workspaceFolder}/install/task_allocator/lib/python3.10/dist-packages",
    "${workspaceFolder}/install/bringup/lib/python3.10/dist-packages"
  ],
  "python.analysis.extraPaths": [
    "/opt/ros/humble/lib/python3.10/dist-packages",
    "/opt/ros/humble/local/lib/python3.10/dist-packages"
  ],
  "files.associations": {
    "*.urdf": "xml",
    "*.xacro": "xml",
    "*.sdf": "xml",
    "*.world": "xml",
    "*.launch.py": "python"
  },
  "editor.formatOnSave": true,
  "python.formatting.provider": "none",
  "[python]": {
    "editor.defaultFormatter": "ms-python.python"
  },
  "xml.fileAssociations": [
    {
      "pattern": "**/*.urdf",
      "systemId": "http://wiki.ros.org/urdf/XML"
    }
  ],
  "search.exclude": {
    "**/build": true,
    "**/install": true,
    "**/log": true
  }
}
