{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Gazebo Warehouse",
      "type": "ros",
      "request": "launch",
      "target": "${workspaceFolder}/src/warehouse_gazebo/launch/sim.launch.py"
    },
    {
      "name": "Launch Full System",
      "type": "ros",
      "request": "launch",
      "target": "${workspaceFolder}/src/bringup/launch/full_system.launch.py"
    },
    {
      "name": "Python: Current File",
      "type": "python",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal"
    }
  ]
}
