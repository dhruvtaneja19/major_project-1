{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ROS2 Build",
      "type": "shell",
      "command": "source /opt/ros/humble/setup.bash && colcon build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "ROS2 Build (symlink-install)",
      "type": "shell",
      "command": "source /opt/ros/humble/setup.bash && colcon build --symlink-install",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "ROS2 Clean Build",
      "type": "shell",
      "command": "rm -rf build/ install/ log/ && source /opt/ros/humble/setup.bash && colcon build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": []
    }
  ]
}
